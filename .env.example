# =============================================================================
# Lucky Biryani Centre — environment template
# Copy to .env and fill in real values when going to staging/prod.
# In dev, all stubs work without any of these set.
# =============================================================================

# --- Core ---
DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-secret-change-me-in-prod"
PORT=4000
FRONTEND_URL="http://localhost:3000"

# --- Razorpay (stub by default; set to real keys to use live gateway) ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# --- MSG91 (SMS + OTP) ---
MSG91_AUTH_KEY=""
MSG91_DLT_TEMPLATE_ID_OTP=""

# --- WhatsApp Cloud API ---
WA_PHONE_NUMBER_ID=""
WA_ACCESS_TOKEN=""
WA_VERIFY_TOKEN="dev-verify-token"

# --- Email (Resend) ---
RESEND_API_KEY=""

# --- Google Maps ---
GOOGLE_MAPS_SERVER_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Image storage (Cloudflare R2 / AWS S3) ---
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION=""

# --- Sentry ---
SENTRY_DSN_BACKEND=""
NEXT_PUBLIC_SENTRY_DSN_FRONTEND=""

# --- Public frontend ---
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# --- Dev overrides ---
DEV_OTP="000000"          # accepted as OTP for any phone in dev mode
ENABLE_AUTOMATION=true    # set false to disable background workers
