# =============================================================================
# Lucky Biryani Centre — environment template
# Copy to apps/api/.env (server) or set on Render / Vercel for prod.
# Every adapter falls back to a working stub when its key is unset, so dev
# boots green with zero keys.
# =============================================================================

# --- Core (always required) ---------------------------------------------------
DATABASE_URL="file:./dev.db"            # prod: postgres connection string from Neon
JWT_SECRET="dev-secret-change-me-in-prod"
PORT=4000
FRONTEND_URL="http://localhost:3000"
ENABLE_AUTOMATION=true                  # set false to disable background workers

# --- AI chatbot (Lucky AI) ----------------------------------------------------
# Without a key, the chatbot uses a deterministic rule-based fallback.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# --- Web push (browser notifications) -----------------------------------------
# Generate once with:   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_CONTACT="mailto:hello@luckybiryani.in"

# --- Payments — Razorpay ------------------------------------------------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# --- SMS / OTP ----------------------------------------------------------------
# Fast2SMS works for any Indian +91 number, no DLT template needed.
FAST2SMS_API_KEY=""
# MSG91 (requires DLT-approved templates, India)
MSG91_AUTH_KEY=""
MSG91_DLT_TEMPLATE_ID_OTP=""

# --- WhatsApp Cloud API -------------------------------------------------------
WA_PHONE_NUMBER_ID=""
WA_ACCESS_TOKEN=""
WA_VERIFY_TOKEN="dev-verify-token"

# --- Email (Brevo preferred, Resend fallback) ---------------------------------
# Brevo (Sendinblue) — free 300/day, sends to ANY address after verifying just
# your sender email (no DNS required).
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="Lucky Biryani"
# Resend (free tier only sends to your own signup email unless domain verified)
RESEND_API_KEY=""
EMAIL_FROM="Lucky Biryani <onboarding@resend.dev>"

# --- Google Maps (live rider tracking) ----------------------------------------
GOOGLE_MAPS_SERVER_KEY=""               # backend (geocoding, distance)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""      # frontend (Maps JS SDK)

# --- Image storage (Cloudflare R2 / AWS S3) -----------------------------------
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION=""

# --- Error monitoring ---------------------------------------------------------
SENTRY_DSN_BACKEND=""
NEXT_PUBLIC_SENTRY_DSN_FRONTEND=""

# --- Public frontend ----------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
API_PROXY_URL="http://localhost:4000"   # used by Next.js rewrites on the server
